<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>           <string>com.runrundeals.dealbot</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/caffeinate</string>
    <string>-i</string>
    <string>__PYTHON__</string>
    <string>__HOME__/tg_dealbot/dealbot.py</string>
  </array>
  <key>WorkingDirectory</key> <string>__HOME__/tg_dealbot</string>
  <key>StandardOutPath</key>  <string>__HOME__/tg_dealbot/dealbot.log</string>
  <key>StandardErrorPath</key><string>__HOME__/tg_dealbot/dealbot.log</string>
  <key>RunAtLoad</key>        <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key> <false/>
    <key>Crashed</key>        <true/>
  </dict>
  <key>ThrottleInterval</key> <integer>30</integer>
</dict>
</plist>
